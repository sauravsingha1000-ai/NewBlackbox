<?xml version="1.0" encoding="utf-8"?><resources><style name="Theme.NewBlackbox" parent="Theme.MaterialComponents.DayNight.NoActionBar">

    <!-- Primary colors -->
    <item name="colorPrimary">@color/colorPrimary</item>
    <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
    <item name="colorOnPrimary">@color/colorOnPrimary</item>

    <!-- Secondary colors -->
    <item name="colorSecondary">@color/colorAccent</item>
    <item name="colorSecondaryVariant">@color/colorAccent</item>
    <item name="colorOnSecondary">@color/black</item>

    <!-- Background -->
    <item name="android:colorBackground">@color/colorBackground</item>

    <!-- Status bar -->
    <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

    <!-- Navigation bar -->
    <item name="android:navigationBarColor">@color/colorBackground</item>

    <!-- Toolbar style -->
    <item name="toolbarStyle">@style/Widget.MaterialComponents.Toolbar</item>

    <!-- Preference screen theme (fix spacing + modern look) -->
    <item name="preferenceTheme">@style/PreferenceThemeOverlay.Material</item>

    <!-- Fix faded settings text -->
    <item name="android:textColorPrimary">@color/black</item>
    <item name="android:textColorSecondary">@color/black</item>

    <!-- Switch style -->
    <item name="switchStyle">@style/Widget.MaterialComponents.CompoundButton.Switch</item>

</style>


<style name="Theme.NewBlackbox.Splash" parent="Theme.NewBlackbox">
    <item name="android:windowFullscreen">true</item>
    <item name="android:windowNoTitle">true</item>
</style>


<style name="Theme.NewBlackbox.Translucent" parent="Theme.NewBlackbox">
    <item name="android:windowIsTranslucent">true</item>
    <item name="android:windowBackground">@android:color/transparent</item>
    <item name="android:windowNoTitle">true</item>
</style>

</resources>
